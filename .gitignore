# Secrets — defensa en profundidad. La ubicacion oficial de credenciales es
# ~/.claude/secrets/ (home del usuario, fuera del repo); estos patrones
# bloquean cualquier intento accidental de crear esos paths dentro del repo.
.claude/secrets/
**/.claude/secrets/
secrets.json
**/secrets.json
.env
.env.*
!.env.example

# Build outputs
build/
*/build/
**/build/

# Gradle
.gradle/
*/.gradle/
**/.gradle/

# Kotlin
.kotlin/

# IDE
.idea/
*.iml
*.iws
*.ipr

# OS
.DS_Store
Thumbs.db

# Android
local.properties
app/local.properties
*.apk
*.aab

# Logs
*.log
app/logs/
logs/

# Node (Wasm)
node_modules/
kotlin-js-store/

# Dependencies dump
deps_commonMain.txt

# Entorno local (generado por scripts/local-up.sh)
.env.local
.env.qa

# QA E2E — recordings y estado del backend
qa/recordings/
qa/.backend.pid

# QA E2E — artefactos de build (JAR + APK generados por /builder)
qa/artifacts/

# QA E2E — tests generados (efímeros, se regeneran con /qa validate)
qa/generated/

# QA E2E — evidencias versionadas (NO ignorar)
!qa/evidence/
# QA E2E — videos locales (pesados, se suben a Google Drive)
qa/evidence/**/*.mp4
qa/evidence/**/*.mp4.tmp
.maestro/tests/

# Claude Code — estado de sesión y logs (no commitear)
.claude/activity-log.jsonl
.claude/permissions-log.jsonl
.claude/session-state.json
.claude/sessions/
.claude/hooks/hook-debug.log
