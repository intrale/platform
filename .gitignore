.claude/hooks/tg-session-store.json
.claude/hooks/activity-logger-stale-check.json
.claude/hooks/session-gc-state.json

# Sprint — archivos de agentes (no commitear, local de trabajo)
scripts/sprint-plan.json
scripts/sprint-pids.json
scripts/logs/

