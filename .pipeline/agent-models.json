        "--system",
        "{system_file}",
        "{user_prompt}"
      ],
      "output_parser": "openai-sse",
      "quota_error_types": [
        "insufficient_quota",
        "billing_hard_limit_reached"
      ],
      "resets_at_cap_max_days": 31,
      "supports_tool_use": true,
      "prompt_caching": {
        "supported": true,
        "auto": true
      },
      "credentials_env": [
        "OPENAI_API_KEY"
      ],
      "permissions_mode": "bypassPermissions"
    },
    "gemini-google": {
