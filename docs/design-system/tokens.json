{
  "$schema": "https://intrale.local/design-system/tokens.schema.json",
  "version": "1.0.0",
  "comment": "Tokens de diseño base Intrale (issue #3381 · CA-UX-4/5). Inyectados al prompt del LLM por ux-mockup-generator.js. Defaults Material 3; tunear cuando #3401 entregue el design-system persistido autoritativo.",
  "palette": {
    "primary": "#4F2DA3",
    "onPrimary": "#FFFFFF",
    "primaryContainer": "#EADDFF",
    "onPrimaryContainer": "#21005D",
    "secondary": "#625B71",
    "onSecondary": "#FFFFFF",
    "secondaryContainer": "#E8DEF8",
    "onSecondaryContainer": "#1D192B",
    "tertiary": "#7D5260",
    "onTertiary": "#FFFFFF",
    "tertiaryContainer": "#FFD8E4",
    "onTertiaryContainer": "#31111D",
    "error": "#B3261E",
    "onError": "#FFFFFF",
    "errorContainer": "#F9DEDC",
    "onErrorContainer": "#410E0B",
    "surface": "#FFFBFE",
    "onSurface": "#1C1B1F",
    "surfaceVariant": "#E7E0EC",
    "onSurfaceVariant": "#49454F",
    "outline": "#79747E",
    "background": "#FFFBFE",
    "onBackground": "#1C1B1F"
  },
  "typography": {
    "fontFamily": "'Inter', 'Roboto', system-ui, -apple-system, sans-serif",
    "displayLarge":  { "size": "57px", "weight": 400, "lineHeight": "64px", "letterSpacing": "-0.25px" },
    "displayMedium": { "size": "45px", "weight": 400, "lineHeight": "52px", "letterSpacing": "0" },
    "displaySmall":  { "size": "36px", "weight": 400, "lineHeight": "44px", "letterSpacing": "0" },
    "headlineLarge": { "size": "32px", "weight": 400, "lineHeight": "40px", "letterSpacing": "0" },
    "headlineMedium":{ "size": "28px", "weight": 400, "lineHeight": "36px", "letterSpacing": "0" },
    "headlineSmall": { "size": "24px", "weight": 400, "lineHeight": "32px", "letterSpacing": "0" },
    "titleLarge":    { "size": "22px", "weight": 500, "lineHeight": "28px", "letterSpacing": "0" },
    "titleMedium":   { "size": "16px", "weight": 500, "lineHeight": "24px", "letterSpacing": "0.15px" },
    "titleSmall":    { "size": "14px", "weight": 500, "lineHeight": "20px", "letterSpacing": "0.1px" },
    "bodyLarge":     { "size": "16px", "weight": 400, "lineHeight": "24px", "letterSpacing": "0.5px" },
    "bodyMedium":    { "size": "14px", "weight": 400, "lineHeight": "20px", "letterSpacing": "0.25px" },
    "bodySmall":     { "size": "12px", "weight": 400, "lineHeight": "16px", "letterSpacing": "0.4px" },
    "labelLarge":    { "size": "14px", "weight": 500, "lineHeight": "20px", "letterSpacing": "0.1px" },
    "labelMedium":   { "size": "12px", "weight": 500, "lineHeight": "16px", "letterSpacing": "0.5px" },
    "labelSmall":    { "size": "11px", "weight": 500, "lineHeight": "16px", "letterSpacing": "0.5px" }
  },
  "spacing": {
    "xs":  "4px",
    "sm":  "8px",
    "md":  "16px",
    "lg":  "24px",
    "xl":  "32px",
    "xxl": "48px"
  },
  "radii": {
    "none":  "0",
    "small": "4px",
    "medium":"8px",
    "large": "16px",
    "xlarge":"28px",
    "full":  "9999px"
  },
  "elevation": {
    "level0": "none",
    "level1": "0 1px 2px rgba(0,0,0,0.30), 0 1px 3px 1px rgba(0,0,0,0.15)",
    "level2": "0 1px 2px rgba(0,0,0,0.30), 0 2px 6px 2px rgba(0,0,0,0.15)",
    "level3": "0 1px 3px rgba(0,0,0,0.30), 0 4px 8px 3px rgba(0,0,0,0.15)"
  },
  "accessibility": {
    "minimumContrastNormal": 4.5,
    "minimumContrastLarge":  3.0,
    "minimumTouchTargetDp":  48,
    "minimumTouchTargetSpacingDp": 8
  }
}
