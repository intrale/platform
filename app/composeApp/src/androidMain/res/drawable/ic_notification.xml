<!--
    Intrale notification icon (status bar / foreground service).

    Designed para issue #2456 (fix de #1915 - notificaciones sonoras de pedidos).

    Spec Android:
    - Viewport 24x24 dp.
    - Pure white silhouette (#FFFFFF) — el sistema tinta el icono segun el tema
      del status bar (blanco sobre dark, gris-negro sobre light).
    - Visual content centrado con padding ~1dp para cumplir lineamientos de
      Material Design para notification icons.

    Composicion (consistente con la marca Intrale - ver ic_intrale_foreground.xml):
    - Triangulo exterior outlined (mark Intrale principal).
    - Triangulo interior filled (mark Intrale secundario).
    - Notification dot top-right que hace semanticamente evidente que se trata
      de una alerta activa (no solo el logo).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer Intrale triangle (outline only) -->
    <path
        android:pathData="M11,3 L2.5,18 L19.5,18 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Inner Intrale triangle (filled, replica del foreground del logo) -->
    <path
        android:pathData="M11,9.5 L7.6,15 L14.4,15 Z"
        android:fillColor="#FFFFFF" />

    <!-- Notification dot (top-right): "alerta activa" -->
    <path
        android:pathData="M19.75,5.25 m-2.25,0 a2.25,2.25 0 1,0 4.5,0 a2.25,2.25 0 1,0 -4.5,0"
        android:fillColor="#FFFFFF" />
</vector>
