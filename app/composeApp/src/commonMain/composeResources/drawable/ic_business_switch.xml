        android:fillColor="#FF000000"
        android:pathData="M14,7.5 L11,7.5 L11,6 L9.5,8 L11,10 L11,8.5 L14,8.5 Z" />
    <!-- Flecha inferior: izquierda -> derecha -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M10,15 L13,15 L13,13.5 L14.5,15.5 L13,17.5 L13,16 L10,16 Z" />
