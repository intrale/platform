        android:fillColor="#FF000000"
        android:pathData="M15,21 L15,3 L21,3 L21,21 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M16.5,5 L17.5,5 L17.5,6 L16.5,6 Z M18.5,5 L19.5,5 L19.5,6 L18.5,6 Z M16.5,7.5 L17.5,7.5 L17.5,8.5 L16.5,8.5 Z M18.5,7.5 L19.5,7.5 L19.5,8.5 L18.5,8.5 Z M16.5,10 L17.5,10 L17.5,11 L16.5,11 Z M18.5,10 L19.5,10 L19.5,11 L18.5,11 Z M16.5,12.5 L17.5,12.5 L17.5,13.5 L16.5,13.5 Z M18.5,12.5 L19.5,12.5 L19.5,13.5 L18.5,13.5 Z M16.5,15 L17.5,15 L17.5,16 L16.5,16 Z M18.5,15 L19.5,15 L19.5,16 L18.5,16 Z M17.25,17.5 L18.75,17.5 L18.75,21 L17.25,21 Z" />

