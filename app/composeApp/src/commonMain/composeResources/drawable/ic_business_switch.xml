    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorControlNormal">

    <!-- Edificio izquierdo (negocio actual) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M3,21 L3,9 L9,9 L9,21 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M4.5,11 L5.5,11 L5.5,12 L4.5,12 Z M6.5,11 L7.5,11 L7.5,12 L6.5,12 Z M4.5,13.5 L5.5,13.5 L5.5,14.5 L4.5,14.5 Z M6.5,13.5 L7.5,13.5 L7.5,14.5 L6.5,14.5 Z M4.5,16 L5.5,16 L5.5,17 L4.5,17 Z M6.5,16 L7.5,16 L7.5,17 L6.5,17 Z M5.25,18.5 L6.75,18.5 L6.75,21 L5.25,21 Z" />

    <!-- Edificio derecho (negocio destino) -->
